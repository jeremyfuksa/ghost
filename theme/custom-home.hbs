{{!< default}}

<div class="home-bg">

<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">Independent Design Leader</div>
    <h1 class="hero-name">Jeremy Fuksa</h1>
    <p class="hero-positioning">I help organizations build design systems that actually ship, UX strategies that connect to business outcomes, and AI-augmented workflows that amplify craft.</p>
    <div class="hero-proof">
      <span>15+ years</span>
      <span class="hero-meta-dot"></span>
      <span>Design Systems</span>
      <span class="hero-meta-dot"></span>
      <span>UX Strategy</span>
      <span class="hero-meta-dot"></span>
      <span>AI-Augmented Design</span>
    </div>
    <div class="hero-actions">
      <a href="/work/" class="hero-cta">Work with me</a>
      <a href="/work/" class="hero-cta-secondary">See my work &rarr;</a>
    </div>
  </div>
</section>

<div class="home-grid">
  <main>
    {{!-- Latest writing --}}
    <div class="section-header">
      <span class="section-title">Latest writing</span>
      <a href="/writing/" class="section-link">All posts &rarr;</a>
    </div>
    {{#get "posts" limit="3"}}
      {{#foreach posts}}
        {{> post-card}}
      {{/foreach}}
    {{/get}}

    {{!-- Portfolio teaser --}}
    <div class="section-header section-header-spaced">
      <span class="section-title">Work</span>
      <a href="/work/" class="section-link">See all work &rarr;</a>
    </div>
    <div class="home-work-teaser">
      <a href="/work/" class="home-work-card">
        <div class="home-work-card-label">Writing &amp; thinking</div>
        <div class="home-work-card-body">Long-form essays on design systems, UX strategy, and craft.</div>
      </a>
      <a href="/work/" class="home-work-card">
        <div class="home-work-card-label">Systems work</div>
        <div class="home-work-card-body">Tokens, components, governance — making design systems stick.</div>
      </a>
      <a href="/work/" class="home-work-card">
        <div class="home-work-card-label">Leadership</div>
        <div class="home-work-card-body">Translating design into the language the business uses.</div>
      </a>
      <a href="/work/#work-with-me" class="home-work-card home-work-card-cta">
        <div class="home-work-card-label">Case studies</div>
        <div class="home-work-card-body">Detailed engagement stories. Available on request.</div>
      </a>
    </div>
  </main>

  {{!-- Sidebar --}}
  <aside class="sidebar">
    {{> now-card}}

    <div class="sidebar-about">
      {{#get "authors" limit="1"}}
        <p>{{bio}}</p>
      {{/get}}
      <ul class="sidebar-about-links">
        <li><a href="/work/"><i class="fa-solid fa-briefcase" aria-hidden="true"></i> Work</a></li>
        <li><a href="https://linkedin.com/in/jeremyfuksa"><i class="fa-brands fa-linkedin" aria-hidden="true"></i> LinkedIn</a></li>
        <li><a href="https://github.com/jeremyfuksa"><i class="fa-brands fa-github" aria-hidden="true"></i> GitHub</a></li>
      </ul>
    </div>

  </aside>
</div>
</div>
