{{!< default}}

<div class="home-bg">

<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">Independent Design Leader</div>
    <h1 class="hero-name">Jeremy Fuksa</h1>
    <p class="hero-positioning">I help organizations build design systems that actually ship, UX strategies that connect to business outcomes, and AI-augmented workflows that amplify craft.</p>
    <div class="hero-proof">
      <span>15+ years</span>
      <span class="hero-meta-dot"></span>
      <span>Design Systems</span>
      <span class="hero-meta-dot"></span>
      <span>UX Strategy</span>
      <span class="hero-meta-dot"></span>
      <span>AI-Augmented Design</span>
    </div>
    <div class="hero-actions">
      <a href="/work/" class="hero-cta">Work with me</a>
      <a href="/work/" class="hero-cta-secondary">See my work &rarr;</a>
    </div>
  </div>
</section>

<div class="home-grid">
  <main>
    {{!-- Latest writing --}}
    <div class="section-header">
      <span class="section-title">Latest writing</span>
      <a href="/writing/" class="section-link">All posts &rarr;</a>
    </div>
    {{#get "posts" limit="3"}}
      {{#foreach posts}}
        {{> post-card}}
      {{/foreach}}
    {{/get}}
  </main>

  {{!-- Sidebar --}}
  <aside class="sidebar">
    {{> now-card}}

    <div class="sidebar-about">
      <p>Independent AI-augmented design leader specializing in design systems, UX strategy, and product design. Based in Kansas City.</p>
      <ul class="sidebar-about-links">
        <li><a href="/work/">Work</a></li>
        <li><a href="https://linkedin.com/in/jeremyfuksa">LinkedIn</a></li>
        <li><a href="https://github.com/jeremyfuksa">GitHub</a></li>
      </ul>
    </div>

    <div class="sidebar-topics">
      <div class="sidebar-topics-title">Topics</div>
      <ul class="sidebar-topics-list">
        {{#get "tags" limit="all" order="count.posts desc"}}
          {{#foreach tags}}
            <li>
              <a href="{{url}}">
                <span>{{name}}</span>
                <span class="topic-count">{{count.posts}}</span>
              </a>
            </li>
          {{/foreach}}
        {{/get}}
      </ul>
    </div>
  </aside>
</div>
</div>
