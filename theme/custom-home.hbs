{{!< default}}

<div class="home-bg">

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-name">Jeremy Fuksa</h1>
    <p class="hero-positioning">I follow my creative thoughts wherever they take me. A couple of years ago, they brought me to AI. I've been sitting at that crossroads ever since.</p>
    <div class="hero-proof">
      <span>30 years</span>
      <span class="hero-meta-dot"></span>
      <span>AI-Augmented Design</span>
      <span class="hero-meta-dot"></span>
      <span>UX Strategy</span>
      <span class="hero-meta-dot"></span>
      <span>Design Systems</span>
    </div>
  </div>
</section>

<section class="featured-work">
  <div class="featured-work-inner">
    <div class="featured-work-card">
      <span class="featured-work-label">Featured Work</span>
      <span class="featured-work-tag">Experiments · AI-Augmented Design</span>
      <h2 class="featured-work-title">Domain Foundation</h2>
      <p class="featured-work-body">Fast doesn't matter in design when the output is just averaged training data. Domain Foundation is a methodology for building the knowledge layer that makes AI tools produce work that actually reflects your domain — not everyone else's.</p>
      <a href="/work/domain-foundation/" class="featured-work-link">Read the case study &rarr;</a>
    </div>
  </div>
</section>

{{#get "pages" filter="slug:testimonial" limit="1"}}
  {{#foreach pages}}
    <section class="testimonial">
      <div class="testimonial-inner">
        <span class="testimonial-label">What people say</span>
        <blockquote class="testimonial-quote">{{{html}}}</blockquote>
        {{#if custom_excerpt}}<cite class="testimonial-cite">{{custom_excerpt}}</cite>{{/if}}
      </div>
    </section>
  {{/foreach}}
{{/get}}

{{#get "pages" filter="tag:hash-methodology" limit="3"}}
  {{#if pages}}
    <section class="methodology-trio">
      <div class="methodology-trio-inner">
        <span class="methodology-trio-label">How I think</span>
        <div class="methodology-trio-grid">
          {{#foreach pages}}
            <a href="{{url}}" class="methodology-tile">
              {{#if primary_tag}}<span class="methodology-tile-eyebrow">{{primary_tag.name}}</span>{{/if}}
              <h3 class="methodology-tile-title">{{title}}</h3>
              {{#if custom_excerpt}}<p class="methodology-tile-body">{{custom_excerpt}}</p>{{/if}}
              <span class="methodology-tile-link">Read &rarr;</span>
            </a>
          {{/foreach}}
        </div>
      </div>
    </section>
  {{/if}}
{{/get}}

{{!-- Editorial override: posts flagged "Feature this post" in Ghost Admin
     populate the hero article + sidebar. Falls back to newest when none. --}}
<div class="home-writing-grid">
  <main>
    <span class="section-title">Latest</span>
    {{#get "posts" filter="featured:true" limit="1" as |hero|}}
      {{#if hero.posts}}
        {{#foreach hero.posts}}
          {{> "post-card-featured"}}
        {{/foreach}}
      {{else}}
        {{#get "posts" limit="1"}}
          {{#foreach posts}}
            {{> "post-card-featured"}}
          {{/foreach}}
        {{/get}}
      {{/if}}
    {{/get}}
  </main>

  <aside class="sidebar">
    <span class="section-title">Previous Writing</span>
    <nav class="sidebar-posts">
      {{#get "posts" filter="featured:true" limit="5" offset="1" as |featured|}}
        {{#if featured.posts}}
          {{#foreach featured.posts}}
            {{> "sidebar-post-link"}}
          {{/foreach}}
        {{else}}
          {{#get "posts" limit="5" offset="1"}}
            {{#foreach posts}}
              {{> "sidebar-post-link"}}
            {{/foreach}}
          {{/get}}
        {{/if}}
      {{/get}}
      <a href="/writing/" class="sidebar-posts-all">All posts &rarr;</a>
    </nav>
  </aside>
</div>

</div>
