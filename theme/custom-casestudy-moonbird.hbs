{{!< default}}

{{#page}}
<div class="casestudy-page">
  <a href="/work/" class="casestudy-back">← Work</a>

  <header class="casestudy-header">
    <div class="casestudy-eyebrow">Research · 2025–2026</div>
    <h1 class="casestudy-title">{{title}}</h1>
    <p class="casestudy-tagline">The opening question was defensive: how do we keep a non-designer from generating something that doesn't match our design system. Answering that tells you what <em>not</em> to allow, not what to build.</p>
  </header>

  <div class="casestudy-body">
    <div class="casestudy-prose">
      {{content}}
    </div>

    <aside class="casestudy-sidebar">
      <div class="cs-meta-group">
        <div class="cs-meta-label">Role</div>
        <div class="cs-meta-value">UX Designer, AI design research</div>
      </div>
      <div class="cs-meta-group">
        <div class="cs-meta-label">Organization</div>
        <div class="cs-meta-value">Oracle Health</div>
      </div>
      <div class="cs-meta-group">
        <div class="cs-meta-label">Timeline</div>
        <div class="cs-meta-value">2025–2026</div>
      </div>

      <hr class="cs-divider">

      <blockquote class="cs-pullquote">The first thing said, in the first meeting, was that AI in the hands of engineering and PM was going to take our jobs.</blockquote>
    </aside>
  </div>

  <section class="post-share" aria-label="Share">
    <div class="post-share-label">Enjoyed this?</div>
    <a class="post-share-cta" href="#/share">
      <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
      Share this case study
    </a>
  </section>

  {{> subscribe-cta}}
</div>
{{/page}}
