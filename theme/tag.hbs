{{!< default}}

<div class="writing-layout writing-layout-single">
  <div class="page-header">
    <div class="page-header-left">
      <h1>{{#if tag}}{{tag.name}}{{else}}Writing{{/if}}</h1>
    </div>
    <span class="page-header-count">{{pagination.total}} posts</span>
  </div>

  {{!-- Filter bar --}}
  <div class="filter-bar">
    <a href="/writing/" class="filter-chip {{#unless tag}}active{{/unless}}">All</a>
    {{#get "tags" limit="100" order="count.posts desc"}}
      {{#foreach tags}}
        <a href="{{url}}" class="filter-chip {{#has slug=../tag.slug}}active{{/has}}">{{name}}</a>
      {{/foreach}}
    {{/get}}
  </div>

  <main>
    {{#foreach posts}}
      {{> post-card}}
    {{/foreach}}

    {{#if pagination.pages}}
      {{#if (match pagination.pages ">" 1)}}
        <div class="pagination">
          {{#if pagination.prev}}
            <a href="{{pagination.prev}}">&larr; Newer</a>
          {{/if}}
          <span class="page-number">Page {{pagination.page}} of {{pagination.pages}}</span>
          {{#if pagination.next}}
            <a href="{{pagination.next}}">Older &rarr;</a>
          {{/if}}
        </div>
      {{/if}}
    {{/if}}
  </main>
</div>
