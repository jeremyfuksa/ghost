{
  "name": "the-cocktail-napkin",
  "description": "Jeremy Fuksa — The Cocktail Napkin",
  "version": "1.0.0",
  "author": {
    "name": "Jeremy Fuksa",
    "email": "jeremy@jeremyfuksa.com"
  },
  "keywords": [
    "ghost",
    "ghost-theme",
    "theme"
  ],
  "engines": {
    "ghost": ">=6.0.0"
  },
  "config": {
    "posts_per_page": 15,
    "image_sizes": {
      "xxs": { "width": 30 },
      "xs": { "width": 100 },
      "s": { "width": 300 },
      "m": { "width": 600 },
      "l": { "width": 1000 },
      "xl": { "width": 2000 }
    },
    "card_assets": true,
    "custom": {
      "show_reading_time": {
        "type": "boolean",
        "default": true,
        "description": "Show reading time on post cards and post headers"
      }
    }
  }
}
