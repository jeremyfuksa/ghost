{{!< default}}

{{!--
  TEMPLATE: custom-work.hbs
  PROPOSED REPLACEMENT — do NOT overwrite the existing file blindly.

  This file proposes a three-orbit structure for /work/ (Methodology /
  Demonstrations / Case Studies). Before applying, diff against the
  existing theme/custom-work.hbs and preserve anything worth keeping —
  especially any additional {{#if}} conditional blocks that let
  Jeremy edit the page via Ghost Admin without a redeploy.

  The conditional blocks below (custom_excerpt, feature_image, content)
  are the known Ghost conveniences worth preserving. If the live file
  has more of them, keep them.

  Deploy via the repo's documented workflow (CLAUDE.md): bump
  theme/package.json version, commit, zip, upload via
  dev/deploy-theme.mjs. Do not SSH-edit on the droplet.
--}}

<div class="work-page">

  <header class="work-header">
    <div class="eyebrow">The Cocktail Napkin</div>
    <h1>{{title}}</h1>

    {{#if custom_excerpt}}
      <p class="work-intro">{{custom_excerpt}}</p>
    {{else}}
      <p class="work-intro">The work falls into three groups. The methodology is Domain Foundation — an architecture for encoding design expertise into AI-reachable form. Demonstrations are how it runs in practice. Case studies are the client-facing enterprise work.</p>
    {{/if}}

    {{#if feature_image}}
      <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="work-hero-image">
    {{/if}}
  </header>

  {{#if content}}
    <section class="work-intro-content">
      {{content}}
    </section>
  {{/if}}

  {{!-- METHODOLOGY --}}
  <section class="work-orbit">
    <header class="work-orbit-header">
      <h2 class="work-orbit-title">Methodology</h2>
      <p class="work-orbit-intro">The methodology, in one place. Domain Foundation is the current form — and, for now, the whole of it.</p>
    </header>

    <div class="work-list">
      <a href="/work/domain-foundation/" class="work-row">
        <div class="work-row-meta">Methodology · 2023–ongoing</div>
        <div class="work-row-title">Domain Foundation</div>
        <div class="work-row-excerpt">A methodology for encoding organizational design expertise into machine-readable knowledge systems for AI-assisted design workflows.</div>
      </a>
    </div>
  </section>

  {{!-- DEMONSTRATIONS --}}
  <section class="work-orbit">
    <header class="work-orbit-header">
      <h2 class="work-orbit-title">Demonstrations</h2>
      <p class="work-orbit-intro">How the methodology runs in practice. Four in production: the Skill Ecosystem, jeremyfuksa.com as an applied case, Jeremy OS, and the Moonbird origin dispatch. Publishing as they're ready.</p>
    </header>
  </section>

  {{!-- CASE STUDIES --}}
  <section class="work-orbit">
    <header class="work-orbit-header">
      <h2 class="work-orbit-title">Case Studies</h2>
      <p class="work-orbit-intro">Enterprise work at Cerner / Oracle Health, where the healthcare UI stakes sharpened the thinking that became Domain Foundation.</p>
    </header>

    <div class="work-list">
      <a href="/work/terra-design-system/" class="work-row">
        <div class="work-row-meta">Case study · 2018–2024</div>
        <div class="work-row-title">Terra Design System</div>
        <div class="work-row-excerpt">Open-source React component library. 80+ components, 200+ icons, WCAG 2.1 AA. Built and led at Cerner / Oracle Health.</div>
      </a>
      <a href="/work/seven-years-in-healthcare-ux/" class="work-row">
        <div class="work-row-meta">Case study · 2018–2024</div>
        <div class="work-row-title">Seven Years in Healthcare UX</div>
        <div class="work-row-excerpt">Revenue cycle product design, design system engineering, and distributed team leadership through a $28B acquisition.</div>
      </a>
      <a href="/work/redwood-health-design/" class="work-row">
        <div class="work-row-meta">Case study · 2024–2026</div>
        <div class="work-row-title">Two Components That Didn't Ship</div>
        <div class="work-row-excerpt">Health-specific components on Oracle's Redwood design system. The ones I remember best are the two we decided to kill.</div>
      </a>
    </div>
  </section>

  {{!-- WORK WITH ME --}}
  <section id="work-with-me" class="work-cta-section">
    <h2 class="work-cta-title">Work with me</h2>
    <p class="work-cta-body">Available for design system engagements, UX strategy consulting, and senior design leadership roles. Based in Kansas City, working with teams anywhere.</p>
    <div class="work-cta-actions">
      <a href="mailto:hello@jeremyfuksa.com" class="hero-cta">Get in touch</a>
      <a href="/about/" class="hero-cta-secondary">About me &rarr;</a>
    </div>
  </section>

</div>
